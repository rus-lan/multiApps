# Generated by mapps — do not edit; regenerated on every mapps init/add.
# Overrides and custom targets go in mk/<dir>.mk files, e.g.:
#   BUILD_api = go build ./cmd/api
#   deploy-api:
#   	cd apps/api && ./deploy.sh

MSG ?=
{{range .Repos}}
# ---- {{.Dir}} ({{.Stack}}) ----
BUILD_{{.Var}} = {{.Build}}
RUN_{{.Var}} = {{.Run}}
TEST_{{.Var}} = {{.Test}}

build-{{.Dir}}:
	cd apps/{{.Dir}} && $(BUILD_{{.Var}})

run-{{.Dir}}:
	cd apps/{{.Dir}} && $(RUN_{{.Var}})

test-{{.Dir}}:
	cd apps/{{.Dir}} && $(TEST_{{.Var}})

pull-{{.Dir}}:
	git -C apps/{{.Dir}} pull

commit-{{.Dir}}:
	@test -n "$(MSG)" || { echo 'MSG is empty — usage: make commit-{{.Dir}} MSG="your message"'; exit 1; }
	git -C apps/{{.Dir}} add -A
	git -C apps/{{.Dir}} commit -m "$(MSG)"

push-{{.Dir}}:
	git -C apps/{{.Dir}} push
{{end}}
build-all:{{range .Repos}} build-{{.Dir}}{{end}}

pull-all:{{range .Repos}} pull-{{.Dir}}{{end}}

status:
{{range .Repos}}	@echo "== {{.Dir}} [$$(git -C apps/{{.Dir}} branch --show-current)]" && git -C apps/{{.Dir}} status --short
{{end}}
list:
{{range .Repos}}	@printf '%-24s %-20s %s\n' '{{.Dir}}' "$$(git -C apps/{{.Dir}} branch --show-current)" '{{.Stack}}'
{{end}}
.PHONY: build-all pull-all status list{{range .Repos}} build-{{.Dir}} run-{{.Dir}} test-{{.Dir}} pull-{{.Dir}} commit-{{.Dir}} push-{{.Dir}}{{end}}

-include mk/*.mk
